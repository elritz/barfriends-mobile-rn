{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": "./",
    "paths": {
      "#/*": ["*"],
      "#/app/*": ["./app/*"],
      "#/preferences": ["types/preferences"],
      "#/ctypes/*": ["types/*"],
      "#/assets/*": ["assets/*"],
      "#/graphql/*": ["graphql/*"],
      "#/reactive": ["reactive/index.tsx"],
      "#/gluestack": ["gluestack-ui.config"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ]
}
