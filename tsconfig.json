{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["*"],
      "#/app/*": ["app/*"],
      "#/preferences": ["types/preferences"],
      "#/ctypes/*": ["types/*"],
      "#/assets/*": ["assets/*"],
      "#/util/*": ["util/*"],
      "#/components/*": ["components/*"],
      "#/helpers/*": ["util/helpers/*"],
      "#/screens/*": ["screens/*"],
      "#/graphql/*": ["graphql/*"],
      "#/library/*": ["library/*"],
      "#/constants/*": ["constants/*"],
      "#/reactive": ["reactive/index.tsx"],
      "#/gluestack": ["gluestack-ui.config"],
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
