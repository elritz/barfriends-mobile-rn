{
  "name": "barfriends",
  "version": "2.0.2",
  "main": "expo-router/entry",
  "scripts": {
    "rc-start": "bun pm cache rm",
    "clean": "rm -rf $TMPDIR/react-* && watchman watch-del-all && k",
    "clean-start": "bun run clean && bun run rc-start",
    "fresh-install": "rm -rf $TMPDIR/react-* && watchman watch-del-all && rm -rf ios/build/ModuleCache/* && rm -rf node_modules/ && bun pm cache rm && bun install",
    "fresh-start": "bun run fresh-install && bun run rc-start",
    "clear-bundler-cache": "rm -rf $TMPDIR/metro-* && rm -rf $TMPDIR/haste-* && rm -rf $TMPDIR/hermes-*",
    "clear-watchmen": "watchman watch-del-all",
    "start": "bunx expo start --dev-client",
    "dev": "NODE_ENV=development bunx expo start",
    "dev-build": "NODE_ENV=development bunx expo start --dev-client",
    "dev-production": "NODE_ENV=production bunx expo start --no-dev --minify",
    "android": "npx expo run:android",
    "ios": "bunx expo run:ios",
    "web": "bunx expo start --web",
    "test": "jest --watchAll",
    "test:watch": "yarn test --watch",
    "test:ci": "yarn test --coverage",
    "test:badges": "yarn test:ci  && jest-coverage-badges --input coverage/coverage-summary.json --output __badges__",
    "eject": "expo eject",
    "gen-s": "graphql-codegen --config codegen-graphql-sub.yml ",
    "gen": "graphql-codegen --config codegen-graphql.ts",
    "gents": "bunx expo customize tsconfig.json",
    "lint": "eslint --ext .tsx --ext .ts ./",
    "verify": "bun run tsc && bun lint --quiet && bun format",
    "lint:css": "bunx stylelint './**/*.tsx'",
    "format": "prettier --check ./",
    "postversion": "react-native-version",
    "expo:login": "eas login -u $EXPO_USERNAME -p $EXPO_PASSWORD",
    "prebuild:ios:production": "bunx cross-env NODE_ENV=production NODE_ENV=production expo prebuild --platform ios --clean",
    "eas:device:create": "eas device:create",
    "eas:build:ios:simulator": "NODE_ENV=development eas build --profile development-simulator --platform ios",
    "eas:build:ios:local:simulator": "NODE_ENV=development eas build --local --profile development-simulator --platform ios",
    "eas:build:ios:local:dev": "eas build --local -p ios --profile development",
    "eas:build:ios:local:preview": "eas build --local -p ios --profile preview",
    "eas:build:ios:test:auto:submit": "NODE_ENV=test eas build -p ios --profile test-ios --auto-submit-with-profile=production",
    "eas:build:ios:dev": "NODE_ENV=development eas build -p ios --profile development --no-wait",
    "eas:build:ios:preview": "NODE_ENV=production eas build -p ios --profile preview --no-wait ",
    "eas:build:ios:preview:auto:submit": "NODE_ENV=production eas build -p ios --profile preview --auto-submit-with-profile=preview",
    "eas:build:ios:production": "NODE_ENV=production eas build -p ios --no-wait --auto-submit",
    "eas:submit:ios:preview:latest": "NODE_ENV=production eas submit -p ios --latest --profile preview",
    "eas:build:android:local": "NODE_ENV=development eas build --local -p android --profile development --no-wait",
    "eas:build:android:dev": "NODE_ENV=development eas build -p android --profile development --no-wait",
    "eas:build:android:preview": "NODE_ENV=production eas build -p android --profile preview --no-wait",
    "eas:build:android:production": "NODE_ENV=production eas build -p android --no-wait --auto-submit ",
    "eas:submit:ios": "NODE_ENV=production eas submit -p ios --latest",
    "eas:submit:android": "NODE_ENV=production eas submit -p android --latest",
    "postinstall": "patch-package"
  },
