{
	"name": "revel",
	"version": "2.1.4",
	"main": "expo-router/entry",
	"scripts": {
		"start": "npx expo start --dev-client",
		"dev2": "ENVIRONMENT=development npx expo start",
		"dev": "ENVIRONMENT=development npx expo start --dev-client",
		"dev-production": "ENVIRONMENT=production npx expo start --no-dev --minify",
		"android": "npx expo run:android",
		"ios": "npx expo run:ios",
		"web": "npx expo start --web",
		"test": "jest --watchAll",
		"test:watch": "yarn test --watch",
		"test:ci": "yarn test --coverage",
		"test:badges": "yarn test:ci  && jest-coverage-badges --input coverage/coverage-summary.json --output __badges__",
		"eject": "expo eject",
		"gen-s": "graphql-codegen --config codegen-graphql-sub.yml ",
		"gen": "graphql-codegen --config codegen-graphql.yml ",
		"lint": "eslint --ext .tsx --ext .ts ./",
		"lint:css": "npx stylelint './**/*.tsx'",
		"format": "prettier --check ./",
		"postversion": "react-native-version",
		"expo:login": "eas login -u $EXPO_USERNAME -p $EXPO_PASSWORD",
		"eas:device:create": "eas device:create",
		"eas:simulator:ios": "ENVIRONMENT=development eas build --profile development-simulator --platform ios",
		"eas:build:ios:local": "ENVIRONMENT=development eas build --local -p ios --profile development",
		"eas:build:ios:dev": "ENVIRONMENT=development eas build -p ios --profile development --no-wait",
		"eas:build:ios:staging": "ENVIRONMENT=staging eas build -p ios --profile staging-ios --no-wait ",
		"eas:build:ios:production": "ENVIRONMENT=production eas build -p ios --no-wait --auto-submit",
		"eas:build:ios:staging:auto:submit": "ENVIRONMENT=staging eas build -p ios --profile staging-ios --auto-submit-with-profile=production",
		"eas:submit:ios:staging:latest": "ENVIRONMENT=staging eas submit -p ios --latest --profile staging-ios",
		"eas:build:android:local": "ENVIRONMENT=development eas build --local -p android --profile development",
		"eas:build:android:dev": "ENVIRONMENT=development eas build -p android --profile development --no-wait",
		"eas:build:android:staging": "ENVIRONMENT=staging eas build -p android --profile staging --no-wait",
		"eas:build:android:production": "ENVIRONMENT=production eas build -p android --no-wait --auto-submit ",
		"eas:submit:ios": "ENVIRONMENT=production eas submit -p ios --latest",
		"eas:submit:android": "ENVIRONMENT=production eas submit -p android --latest"
	},
