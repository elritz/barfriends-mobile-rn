{
	"cli": {
		"version": ">=7.1.3",
		"appVersionSource": "remote"
	},
	"build": {
		"fast": {
			"ios": {
				"resourceClass": "m-medium"
			}
		},
		"development-simulator": {
			"env": {
				"NODE_ENV": "development"
			},
			"channel": "development",
			"developmentClient": true,
			"distribution": "internal",
			"ios": {
				"simulator": true
			}
		},
		"development": {
			"env": {
				"NODE_ENV": "development"
			},
			"channel": "development",
			"developmentClient": true,
			"distribution": "internal",
			"extends": "fast"
		},
		"test-ios": {
			"channel": "staging-ios",
			"distribution": "internal",
			"env": {
				"NODE_ENV": "test"
			},
			"extends": "fast"
		},
		"test-android": {
			"channel": "staging-android",
			"env": {
				"NODE_ENV": "test"
			}
		},
		"production-ios": {
			"channel": "production-ios",
			"env": {
				"NODE_ENV": "production"
			}
		},
		"production-android": {
			"channel": "production-android",
			"env": {
				"NODE_ENV": "production"
			}
		}
	},
	"submit": {
		"production": {}
	}
}
